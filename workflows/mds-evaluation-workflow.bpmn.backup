<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.5.0">
  <bpmn:message id="Message_MDSCallback" name="mds-callback">
    <bpmn:extensionElements>
      <zeebe:subscription correlationKey="=cbsJobId" />
    </bpmn:extensionElements>
  </bpmn:message>
  <bpmn:collaboration id="Collaboration_MDS">
    <bpmn:participant id="Participant_CBSSystem" name="CBS Playground – MDS Evaluation Workflow" processRef="mds-evaluation-workflow" />
    <bpmn:participant id="Participant_UtilService" name="Util Service (Deployed Micro‑service)" />
    <bpmn:participant id="Participant_MDS" name="MDS – Moderation Service (External)" />
    <bpmn:messageFlow id="MsgFlow_UtilUploadGCS" name="POST /gcs/upload" sourceRef="Task_UploadGCS" targetRef="Participant_UtilService" />
    <bpmn:messageFlow id="MsgFlow_UtilUploadAEM" name="POST /aem/upload" sourceRef="Task_UploadAEM" targetRef="Participant_UtilService" />
    <bpmn:messageFlow id="MsgFlow_UtilStoreJob" name="POST /postgres/upsert" sourceRef="Task_StoreJobMetadata" targetRef="Participant_UtilService" />
    <bpmn:messageFlow id="MsgFlow_UtilBuildJson" name="POST /gcs/upload (input.json)" sourceRef="Task_BuildInputJson" targetRef="Participant_UtilService" />
    <bpmn:messageFlow id="MsgFlow_UtilSubmitMDS" name="POST /mds/submit" sourceRef="Task_SubmitMDS" targetRef="Participant_UtilService" />
    <bpmn:messageFlow id="MsgFlow_UtilToMDS" name="Submit Async Job" sourceRef="Participant_UtilService" targetRef="Participant_MDS" />
    <bpmn:messageFlow id="MsgFlow_MDSCallback" name="Callback (webhook)" sourceRef="Participant_MDS" targetRef="Event_WaitMDSCallback" />
    <bpmn:messageFlow id="MsgFlow_UtilPostprocess" name="GET /gcs/read + POST /postgres" sourceRef="Task_PostprocessResults" targetRef="Participant_UtilService" />
  </bpmn:collaboration>
  <bpmn:process id="mds-evaluation-workflow" name="MDS Asset Evaluation Workflow" isExecutable="true">
    <bpmn:extensionElements>
      <zeebe:userTaskForm id="UserTaskForm_1njv403"></zeebe:userTaskForm>
    </bpmn:extensionElements>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_HumanReview" name="Human Review">
        <bpmn:flowNodeRef>Task_HumanReview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Automation" name="Automated (Workers)">
        <bpmn:flowNodeRef>StartEvent_Upload</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ValidateAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UploadGCS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UploadAEM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreJobMetadata</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BuildInputJson</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SubmitMDS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_WaitMDSCallback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PostprocessResults</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ReviewDecision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ApproveAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublishAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Published</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RejectAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Rejected</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Upload" name="User Uploads&#10;Assets">
      <bpmn:outgoing>Flow_ToValidate</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_ValidateAssets" name="Validate Asset&#10;Filenames">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validate-asset-filenames" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToValidate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUploadGCS</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UploadGCS" name="Upload Assets&#10;to GCS">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="upload-assets-gcs" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToUploadGCS</bpmn:incoming>
      <bpmn:outgoing>Flow_ToUploadAEM</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_UploadAEM" name="Upload Assets&#10;to AEM">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="upload-assets-aem" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToUploadAEM</bpmn:incoming>
      <bpmn:outgoing>Flow_ToStoreMetadata</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_StoreJobMetadata" name="Store Job Metadata&#10;(Postgres)">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="store-job-metadata" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToStoreMetadata</bpmn:incoming>
      <bpmn:outgoing>Flow_ToBuildInput</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_BuildInputJson" name="Build input.json&#10;Upload to GCS">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="build-mds-input-json" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToBuildInput</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSubmitMDS</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_SubmitMDS" name="Submit Async Job&#10;to MDS">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="submit-mds-job" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToSubmitMDS</bpmn:incoming>
      <bpmn:outgoing>Flow_ToWaitCallback</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_WaitMDSCallback" name="Wait for MDS&#10;Callback">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=mdsJobId" target="mdsJobId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToWaitCallback</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPostprocess</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="Message_MDSCallback" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_PostprocessResults" name="Postprocess MDS&#10;Results">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="postprocess-mds-results" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToPostprocess</bpmn:incoming>
      <bpmn:outgoing>Flow_ToReview</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_HumanReview" name="Review and&#10;Approve Assets">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="reviewer" />
        <zeebe:formDefinition formId="review-assets-form" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToReview</bpmn:incoming>
      <bpmn:incoming>Flow_BackToReview</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDecision</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
  
  <zeebe:userTaskForm id="review-assets-form">
    {
      "schemaVersion": 2,
      "components": [
        {
          "text": "## Review Assets for Approval\n\nReview the MDS evaluation results and decide whether to approve, request changes, or reject the assets.",
          "type": "text",
          "id": "Field_instructions"
        },
        {
          "label": "Assets",
          "type": "textarea",
          "id": "processedAssets",
          "key": "processedAssets",
          "readonly": true,
          "description": "Assets evaluated by MDS"
        },
        {
          "label": "Decision",
          "type": "select",
          "id": "Field_reviewDecision",
          "key": "reviewDecision",
          "description": "Select your decision",
          "validate": {
            "required": true
          },
          "values": [
            {
              "label": "Approve",
              "value": "approved"
            },
            {
              "label": "Request Changes",
              "value": "feedback"
            },
            {
              "label": "Reject",
              "value": "rejected"
            }
          ]
        },
        {
          "label": "Comments",
          "type": "textarea",
          "id": "Field_feedbackText",
          "key": "feedbackText",
          "description": "Optional feedback or comments"
        }
      ],
      "type": "default",
      "id": "review-assets-form",
      "executionPlatform": "Camunda Cloud",
      "executionPlatformVersion": "8.5.0"
    }
  </zeebe:userTaskForm>
  
  <bpmn:process id="mds-evaluation-workflow-placeholder" isExecutable="false">
  </bpmn:process>
    <bpmn:exclusiveGateway id="Gateway_ReviewDecision" name="Review&#10;Decision">
      <bpmn:incoming>Flow_ToDecision</bpmn:incoming>
      <bpmn:outgoing>Flow_Approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_NeedsFeedback</bpmn:outgoing>
      <bpmn:outgoing>Flow_Rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ApproveAssets" name="Mark Assets&#10;Approved">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="approve-assets" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approved</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPublish</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_PublishAssets" name="Publish Approved&#10;Assets">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-approved-assets" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_ToPublish</bpmn:incoming>
      <bpmn:outgoing>Flow_ToComplete</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Published" name="Assets Published">
      <bpmn:incoming>Flow_ToComplete</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_StoreFeedback" name="Store Reviewer&#10;Feedback">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="store-asset-feedback" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_NeedsFeedback</bpmn:incoming>
      <bpmn:outgoing>Flow_BackToReview</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_RejectAssets" name="Mark Assets&#10;Rejected">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="reject-assets" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Rejected" name="Assets Rejected">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToValidate" sourceRef="StartEvent_Upload" targetRef="Task_ValidateAssets" />
    <bpmn:sequenceFlow id="Flow_ToUploadGCS" sourceRef="Task_ValidateAssets" targetRef="Task_UploadGCS" />
    <bpmn:sequenceFlow id="Flow_ToUploadAEM" sourceRef="Task_UploadGCS" targetRef="Task_UploadAEM" />
    <bpmn:sequenceFlow id="Flow_ToStoreMetadata" sourceRef="Task_UploadAEM" targetRef="Task_StoreJobMetadata" />
    <bpmn:sequenceFlow id="Flow_ToBuildInput" sourceRef="Task_StoreJobMetadata" targetRef="Task_BuildInputJson" />
    <bpmn:sequenceFlow id="Flow_ToSubmitMDS" sourceRef="Task_BuildInputJson" targetRef="Task_SubmitMDS" />
    <bpmn:sequenceFlow id="Flow_ToWaitCallback" sourceRef="Task_SubmitMDS" targetRef="Event_WaitMDSCallback" />
    <bpmn:sequenceFlow id="Flow_ToPostprocess" sourceRef="Event_WaitMDSCallback" targetRef="Task_PostprocessResults" />
    <bpmn:sequenceFlow id="Flow_ToReview" sourceRef="Task_PostprocessResults" targetRef="Task_HumanReview" />
    <bpmn:sequenceFlow id="Flow_BackToReview" sourceRef="Task_StoreFeedback" targetRef="Task_HumanReview" />
    <bpmn:sequenceFlow id="Flow_ToDecision" sourceRef="Task_HumanReview" targetRef="Gateway_ReviewDecision" />
    <bpmn:sequenceFlow id="Flow_Approved" name="Approved" sourceRef="Gateway_ReviewDecision" targetRef="Task_ApproveAssets">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_NeedsFeedback" name="Needs Changes" sourceRef="Gateway_ReviewDecision" targetRef="Task_StoreFeedback">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "feedback"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Rejected" name="Rejected" sourceRef="Gateway_ReviewDecision" targetRef="Task_RejectAssets">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "rejected"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToPublish" sourceRef="Task_ApproveAssets" targetRef="Task_PublishAssets" />
    <bpmn:sequenceFlow id="Flow_ToComplete" sourceRef="Task_PublishAssets" targetRef="EndEvent_Published" />
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_RejectAssets" targetRef="EndEvent_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_MDS">
      <bpmndi:BPMNShape id="Shape_Participant_CBSSystem" bpmnElement="Participant_CBSSystem" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="2200" height="520" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_HumanReview" bpmnElement="Lane_HumanReview" isHorizontal="true">
        <dc:Bounds x="150" y="470" width="2170" height="130" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Automation" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="2170" height="390" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent_Upload" bpmnElement="StartEvent_Upload" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="192" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="177" y="305" width="67" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ValidateAssets" bpmnElement="Task_ValidateAssets" bioc:stroke="#1e4d78" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#1e4d78">
        <dc:Bounds x="280" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_UploadGCS" bpmnElement="Task_UploadGCS" bioc:stroke="#0d4372" bioc:fill="#b3e5fc" color:background-color="#b3e5fc" color:border-color="#0d4372">
        <dc:Bounds x="450" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_UploadAEM" bpmnElement="Task_UploadAEM" bioc:stroke="#0d4372" bioc:fill="#b3e5fc" color:background-color="#b3e5fc" color:border-color="#0d4372">
        <dc:Bounds x="620" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_StoreJobMetadata" bpmnElement="Task_StoreJobMetadata" bioc:stroke="#4a148c" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#4a148c">
        <dc:Bounds x="790" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_BuildInputJson" bpmnElement="Task_BuildInputJson" bioc:stroke="#1e4d78" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#1e4d78">
        <dc:Bounds x="960" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_SubmitMDS" bpmnElement="Task_SubmitMDS" bioc:stroke="#6b3304" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3304">
        <dc:Bounds x="1130" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Event_WaitMDSCallback" bpmnElement="Event_WaitMDSCallback" bioc:stroke="#6b3304" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3304">
        <dc:Bounds x="1302" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1288" y="305" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_PostprocessResults" bpmnElement="Task_PostprocessResults" bioc:stroke="#4a148c" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#4a148c">
        <dc:Bounds x="1390" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_HumanReview" bpmnElement="Task_HumanReview" bioc:stroke="#6b3304" bioc:fill="#fff9c4" color:background-color="#fff9c4" color:border-color="#6b3304">
        <dc:Bounds x="1560" y="490" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_ReviewDecision" bpmnElement="Gateway_ReviewDecision" isMarkerVisible="true">
        <dc:Bounds x="1735" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1739" y="312" width="43" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ApproveAssets" bpmnElement="Task_ApproveAssets" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="1840" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_PublishAssets" bpmnElement="Task_PublishAssets" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="2010" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Published" bpmnElement="EndEvent_Published" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="2182" y="262" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2158" y="305" width="85" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_StoreFeedback" bpmnElement="Task_StoreFeedback" bioc:stroke="#6b3304" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#6b3304">
        <dc:Bounds x="1840" y="370" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_RejectAssets" bpmnElement="Task_RejectAssets" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="1840" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_Rejected" bpmnElement="EndEvent_Rejected" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="2012" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1990" y="185" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_ToValidate" bpmnElement="Flow_ToValidate">
        <di:waypoint x="228" y="280" />
        <di:waypoint x="280" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToUploadGCS" bpmnElement="Flow_ToUploadGCS">
        <di:waypoint x="400" y="280" />
        <di:waypoint x="450" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToUploadAEM" bpmnElement="Flow_ToUploadAEM">
        <di:waypoint x="570" y="280" />
        <di:waypoint x="620" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToStoreMetadata" bpmnElement="Flow_ToStoreMetadata">
        <di:waypoint x="740" y="280" />
        <di:waypoint x="790" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToBuildInput" bpmnElement="Flow_ToBuildInput">
        <di:waypoint x="910" y="280" />
        <di:waypoint x="960" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToSubmitMDS" bpmnElement="Flow_ToSubmitMDS">
        <di:waypoint x="1080" y="280" />
        <di:waypoint x="1130" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToWaitCallback" bpmnElement="Flow_ToWaitCallback">
        <di:waypoint x="1250" y="280" />
        <di:waypoint x="1302" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToPostprocess" bpmnElement="Flow_ToPostprocess">
        <di:waypoint x="1338" y="280" />
        <di:waypoint x="1390" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ToReview" bpmnElement="Flow_ToReview">
        <di:waypoint x="1510" y="280" />
