{
  "schemaVersion": 8,
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.14.0"
  },
  "components": [
    {
      "text": "## Review MDS Evaluation Results\n\nThe assets below have been evaluated by MDS (Moderation Service). Review the confidence scores and violations, then click **Complete** to acknowledge and close this task.",
      "label": "Text view",
      "type": "text",
      "layout": {
        "row": "Row_0",
        "columns": null
      },
      "id": "Field_Instructions"
    },
    {
      "label": "Job ID",
      "type": "textfield",
      "layout": {
        "row": "Row_1",
        "columns": 6
      },
      "id": "Field_JobId",
      "key": "cbsJobId",
      "description": "CBS Job identifier",
      "readonly": true
    },
    {
      "label": "MDS Job ID",
      "type": "textfield",
      "layout": {
        "row": "Row_1",
        "columns": 6
      },
      "id": "Field_MdsJobId",
      "key": "mdsJobId",
      "description": "MDS Job identifier",
      "readonly": true
    },
    {
      "label": "Processed Assets (MDS Results)",
      "type": "textarea",
      "layout": {
        "row": "Row_2",
        "columns": null
      },
      "id": "Field_ProcessedAssets",
      "key": "processedAssets",
      "description": "JSON array of assets with MDS scores and violations",
      "readonly": true,
      "rows": 10
    }
  ],
  "type": "default",
  "id": "Form_ReviewAssets",
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.5.0"
}
