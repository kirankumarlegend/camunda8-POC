{
  "schemaVersion": 8,
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.14.0"
  },
  "components": [
    {
      "text": "## Review MDS Evaluation Results\n\nReview the assets that have been evaluated by the MDS (Moderation Service) and decide whether to approve, request changes, or reject them.",
      "label": "Text view",
      "type": "text",
      "layout": {
        "row": "Row_0",
        "columns": null
      },
      "id": "Field_Instructions"
    },
    {
      "label": "Processed Assets",
      "type": "textarea",
      "layout": {
        "row": "Row_1",
        "columns": null
      },
      "id": "Field_ProcessedAssets",
      "key": "processedAssets",
      "description": "JSON array of assets with MDS scores and violations",
      "readonly": true,
      "rows": 8
    },
    {
      "values": [
        {
          "label": "Approve",
          "value": "approved"
        },
        {
          "label": "Request Changes",
          "value": "feedback"
        },
        {
          "label": "Reject",
          "value": "rejected"
        }
      ],
      "label": "Review Decision",
      "type": "select",
      "layout": {
        "row": "Row_2",
        "columns": null
      },
      "id": "Field_ReviewDecision",
      "key": "reviewDecision",
      "description": "Select your decision for these assets",
      "validate": {
        "required": true
      }
    },
    {
      "label": "Feedback / Comments",
      "type": "textarea",
      "layout": {
        "row": "Row_3",
        "columns": null
      },
      "id": "Field_FeedbackText",
      "key": "feedbackText",
      "description": "Optional: Provide feedback or comments about the assets",
      "rows": 4
    }
  ],
  "type": "default",
  "id": "Form_ReviewAssets",
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.5.0"
}
