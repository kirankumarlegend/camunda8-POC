{
  "schemaVersion": 8,
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.14.0"
  },
  "components": [
    {
      "text": "## Review MDS Evaluation Results\n\nReview the assets evaluated by MDS. Select a decision and click **Complete**.",
      "label": "Text view",
      "type": "text",
      "layout": {
        "row": "Row_0",
        "columns": null
      },
      "id": "Field_Instructions"
    },
    {
      "label": "Job ID",
      "type": "textfield",
      "layout": {
        "row": "Row_1",
        "columns": 6
      },
      "id": "Field_JobId",
      "key": "cbsJobId",
      "description": "CBS Job identifier",
      "readonly": true
    },
    {
      "label": "MDS Job ID",
      "type": "textfield",
      "layout": {
        "row": "Row_1",
        "columns": 6
      },
      "id": "Field_MdsJobId",
      "key": "mdsJobId",
      "description": "MDS Job identifier",
      "readonly": true
    },
    {
      "label": "Processed Assets (MDS Results)",
      "type": "textarea",
      "layout": {
        "row": "Row_2",
        "columns": null
      },
      "id": "Field_ProcessedAssets",
      "key": "processedAssets",
      "description": "JSON array of assets with confidence scores and violations",
      "readonly": true,
      "rows": 10
    },
    {
      "label": "Review Decision",
      "type": "radio",
      "layout": {
        "row": "Row_3",
        "columns": null
      },
      "id": "Field_ReviewDecision",
      "key": "reviewDecision",
      "description": "Select your decision for these assets",
      "values": [
        {
          "label": "✅  Approve",
          "value": "approved"
        },
        {
          "label": "❌  Reject",
          "value": "rejected"
        }
      ],
      "validate": {
        "required": true
      }
    }
  ],
  "type": "default",
  "id": "Form_ReviewAssets",
  "executionPlatform": "Camunda Cloud",
  "executionPlatformVersion": "8.5.0"
}
