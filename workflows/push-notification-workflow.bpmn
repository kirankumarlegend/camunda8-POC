<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:modeler="http://camunda.org/schema/modeler/1.0"
  xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0"
  xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0"
  id="Definitions_1"
  targetNamespace="http://bpmn.io/schema/bpmn"
  exporter="Camunda Modeler"
  exporterVersion="5.14.0"
  modeler:executionPlatform="Camunda Cloud"
  modeler:executionPlatformVersion="8.5.0">

  <!-- ================================================================
       Collaboration (Pools)
  ================================================================ -->
  <bpmn:collaboration id="Collaboration_PushNotification">
    <bpmn:participant id="Participant_CBSSystem" name="CBS Playground – Push Notification Workflow" processRef="push-notification-workflow" />
    <bpmn:participant id="Participant_MCPServer" name="MCP Server (Content Generation)" />
    <bpmn:participant id="Participant_Workfront" name="Workfront (Campaign Management)" />
    <bpmn:messageFlow id="MsgFlow_GetWorkfront" name="GET /workfront-get-metadata" sourceRef="Task_GetWorkfront" targetRef="Participant_Workfront" />
    <bpmn:messageFlow id="MsgFlow_Generate" name="POST /generate-push-notifications" sourceRef="Task_Generate" targetRef="Participant_MCPServer" />
    <bpmn:messageFlow id="MsgFlow_Upload" name="POST /aem-upload-asset" sourceRef="Task_Publish" targetRef="Participant_MCPServer" />
    <bpmn:messageFlow id="MsgFlow_Email" name="POST /send-email" sourceRef="Task_Publish" targetRef="Participant_MCPServer" />
  </bpmn:collaboration>

  <!-- ================================================================
       Process
  ================================================================ -->
  <bpmn:process id="push-notification-workflow" name="Push Notification Generation Workflow" isExecutable="true">

    <!-- ─── Lanes ─── -->
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Automation" name="Automated (Workers)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GetWorkfront</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Generate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StoreFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Decision</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Publish</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HumanReview" name="Human Review">
        <bpmn:flowNodeRef>Task_HumanReview</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start -->
    <bpmn:startEvent id="StartEvent_1" name="Campaign Status&#10;Changed">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- Task 1: Get Workfront Metadata -->
    <bpmn:serviceTask id="Task_GetWorkfront" name="Get Workfront&#10;Metadata">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="get-workfront-metadata" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task 2: Generate Push Notifications -->
    <bpmn:serviceTask id="Task_Generate" name="Generate Push&#10;Notifications">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="generate-push-notifications" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:incoming>Flow_Regenerate</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Task 3: Human Review -->
    <bpmn:userTask id="Task_HumanReview" name="Review &amp;&#10;Provide Feedback">
      <bpmn:extensionElements>
        <zeebe:assignmentDefinition assignee="demo" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Gateway: Decision -->
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Review&#10;Decision" default="Flow_Approve">
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Branch A: Approved -->
    <bpmn:serviceTask id="Task_Publish" name="Publish to CRM&#10;System">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="publish-notifications" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Branch B: Needs Regeneration -->
    <bpmn:serviceTask id="Task_StoreFeedback" name="Store Feedback&#10;for Improvement">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="store-feedback" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_Regenerate</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- End -->
    <bpmn:endEvent id="EndEvent_1" name="Notifications&#10;Published">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_GetWorkfront" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_GetWorkfront" targetRef="Task_Generate" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Generate" targetRef="Task_HumanReview" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="Task_HumanReview" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_Approve" name="Approved" sourceRef="Gateway_Decision" targetRef="Task_Publish" />
    <bpmn:sequenceFlow id="Flow_Reject" name="Needs&#10;Regeneration" sourceRef="Gateway_Decision" targetRef="Task_StoreFeedback">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=reviewDecision = "regenerate"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Regenerate" sourceRef="Task_StoreFeedback" targetRef="Task_Generate" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_Publish" targetRef="EndEvent_1" />

  </bpmn:process>

  <!-- ================================================================
       Diagram
  ================================================================ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_PushNotification">

      <!-- Participant: CBS System (Main Pool) -->
      <bpmndi:BPMNShape id="Participant_CBSSystem_di" bpmnElement="Participant_CBSSystem" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1200" height="400" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lane: Automation -->
      <bpmndi:BPMNShape id="Lane_Automation_di" bpmnElement="Lane_Automation" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="1170" height="280" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Lane: Human Review -->
      <bpmndi:BPMNShape id="Lane_HumanReview_di" bpmnElement="Lane_HumanReview" isHorizontal="true">
        <dc:Bounds x="190" y="360" width="1170" height="120" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Start Event -->
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1" bioc:stroke="#43a047" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#43a047">
        <dc:Bounds x="252" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="238" y="205" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Get Workfront -->
      <bpmndi:BPMNShape id="Task_GetWorkfront_di" bpmnElement="Task_GetWorkfront" bioc:stroke="#1e88e5" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#1e88e5">
        <dc:Bounds x="340" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Generate -->
      <bpmndi:BPMNShape id="Task_Generate_di" bpmnElement="Task_Generate" bioc:stroke="#8e24aa" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#8e24aa">
        <dc:Bounds x="490" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Human Review -->
      <bpmndi:BPMNShape id="Task_HumanReview_di" bpmnElement="Task_HumanReview" bioc:stroke="#fb8c00" bioc:fill="#ffe0b2" color:background-color="#ffe0b2" color:border-color="#fb8c00">
        <dc:Bounds x="640" y="380" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Gateway: Decision -->
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true" bioc:stroke="#e53935" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#e53935">
        <dc:Bounds x="795" y="155" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="125" width="50" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Store Feedback -->
      <bpmndi:BPMNShape id="Task_StoreFeedback_di" bpmnElement="Task_StoreFeedback" bioc:stroke="#fdd835" bioc:fill="#fff9c4" color:background-color="#fff9c4" color:border-color="#fdd835">
        <dc:Bounds x="770" y="250" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Task: Publish -->
      <bpmndi:BPMNShape id="Task_Publish_di" bpmnElement="Task_Publish" bioc:stroke="#00897b" bioc:fill="#b2dfdb" color:background-color="#b2dfdb" color:border-color="#00897b">
        <dc:Bounds x="900" y="140" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- End Event -->
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1" bioc:stroke="#e53935" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#e53935">
        <dc:Bounds x="1052" y="162" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1038" y="205" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Participant: MCP Server -->
      <bpmndi:BPMNShape id="Participant_MCPServer_di" bpmnElement="Participant_MCPServer" isHorizontal="true">
        <dc:Bounds x="160" y="520" width="1200" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Participant: Workfront -->
      <bpmndi:BPMNShape id="Participant_Workfront_di" bpmnElement="Participant_Workfront" isHorizontal="true">
        <dc:Bounds x="160" y="600" width="1200" height="60" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <!-- Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="288" y="180" />
        <di:waypoint x="340" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="440" y="180" />
        <di:waypoint x="490" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="590" y="180" />
        <di:waypoint x="615" y="180" />
        <di:waypoint x="615" y="420" />
        <di:waypoint x="640" y="420" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="740" y="420" />
        <di:waypoint x="768" y="420" />
        <di:waypoint x="768" y="180" />
        <di:waypoint x="795" y="180" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Approve_di" bpmnElement="Flow_Approve">
        <di:waypoint x="845" y="180" />
        <di:waypoint x="900" y="180" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="851" y="162" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Reject_di" bpmnElement="Flow_Reject">
        <di:waypoint x="820" y="205" />
        <di:waypoint x="820" y="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="826" y="216" width="58" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Regenerate_di" bpmnElement="Flow_Regenerate">
        <di:waypoint x="770" y="290" />
        <di:waypoint x="540" y="290" />
        <di:waypoint x="540" y="220" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6_di" bpmnElement="Flow_6">
        <di:waypoint x="1000" y="180" />
        <di:waypoint x="1052" y="180" />
      </bpmndi:BPMNEdge>

      <!-- Message Flows -->
      <bpmndi:BPMNEdge id="MsgFlow_GetWorkfront_di" bpmnElement="MsgFlow_GetWorkfront">
        <di:waypoint x="390" y="220" />
        <di:waypoint x="390" y="600" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="395" y="403" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MsgFlow_Generate_di" bpmnElement="MsgFlow_Generate">
        <di:waypoint x="540" y="220" />
        <di:waypoint x="540" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="545" y="363" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MsgFlow_Upload_di" bpmnElement="MsgFlow_Upload">
        <di:waypoint x="920" y="220" />
        <di:waypoint x="920" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="925" y="363" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MsgFlow_Email_di" bpmnElement="MsgFlow_Email">
        <di:waypoint x="980" y="220" />
        <di:waypoint x="980" y="520" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="985" y="363" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
